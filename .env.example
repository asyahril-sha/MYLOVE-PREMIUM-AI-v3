# MYLOVE PREMIUM AI - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# TELEGRAM BOT
# =============================================================================
# Dapatkan dari @BotFather di Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# =============================================================================
# AI DEEPSEEK
# =============================================================================
# Dapatkan dari platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =============================================================================
# ADMIN
# =============================================================================
# ID Telegram admin (bisa didapat dari @userinfobot)
ADMIN_ID=0

# =============================================================================
# DATABASE
# =============================================================================
DB_PATH=data/mylove.db
DB_TYPE=sqlite
DB_POOL_SIZE=5
DB_TIMEOUT=30

# =============================================================================
# AI CONFIGURATION
# =============================================================================
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=2000
AI_TIMEOUT=30
AI_MODEL=deepseek-chat

# Response length
MIN_MESSAGE_LENGTH=500
MAX_MESSAGE_LENGTH=2000

# =============================================================================
# WEBHOOK
# =============================================================================
# Railway akan otomatis memberikan domain, biarkan kosong untuk auto-detect
WEBHOOK_URL=
PORT=8080
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
WEBHOOK_MAX_RETRIES=5
ENABLE_POLLING_FALLBACK=true

# Railway auto-detect (jangan diubah)
RAILWAY_PUBLIC_DOMAIN=
RAILWAY_STATIC_URL=

# =============================================================================
# FEATURE TOGGLES
# =============================================================================
SEXUAL_CONTENT_ENABLED=true
PUBLIC_RISK_ENABLED=true
BOT_INITIATIVE_ENABLED=true
AFTERCARE_ENABLED=true
THREESOME_ENABLED=true
MEMORY_ENABLED=true

# =============================================================================
# INTIMACY SYSTEM
# =============================================================================
RESET_LEVEL=7
MAX_LEVEL=12
AFTERCARE_ENABLED=true

# =============================================================================
# CHEMISTRY & MOOD
# =============================================================================
CHEMISTRY_DECAY=0.01
MOOD_EVOLUTION=0.1
DREAM_CHANCE=0.3
SIXTH_SENSE_CHANCE=0.15

# =============================================================================
# SESSION
# =============================================================================
SESSION_STORAGE=sqlite+json
SESSION_DIR=data/sessions
SESSION_RETENTION_DAYS=30
SESSION_AUTO_DELETE=true

# =============================================================================
# MEMORY
# =============================================================================
VECTOR_DB_DIR=data/vector_db
WORKING_MEMORY_CAPACITY=20
WORKING_MEMORY_EXPIRE=86400
CONSOLIDATION_INTERVAL=3600
FORGETTING_THRESHOLD=0.3

# =============================================================================
# BACKUP
# =============================================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=data/backups
BACKUP_S3_BUCKET=

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=data/logs
