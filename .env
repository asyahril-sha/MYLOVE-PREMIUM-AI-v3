# Telegram Bot Token (dari @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# DeepSeek API Key (dari platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Admin Telegram ID (dapatkan dari @userinfobot)
ADMIN_ID=123456789

# Database
DB_PATH=data/mylove.db

# AI Configuration
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=2000

# Feature Toggles
SEXUAL_CONTENT_ENABLED=true
MEMORY_ENABLED=true
EMOTIONAL_FLOW_ENABLED=true
SPATIAL_AWARENESS_ENABLED=true
ROLE_BEHAVIOR_ENABLED=true
